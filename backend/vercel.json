{
  "version": 2,
  "installCommand": "npm install --os=linux --cpu=x64 sharp && npm install",
  "functions": {
    "server.js": {
      "includeFiles": "routes/**,controllers/**,models/**,middleware/**,utils/**,socket/**,scripts/**,seed/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/server.js" }
  ]
}
